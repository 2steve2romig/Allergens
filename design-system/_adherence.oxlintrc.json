{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/suretrend/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Open Sans|Arial|Arial Narrow))/i]",
        "message": "Font not provided by the design system. Available: Open Sans, Arial, Arial Narrow."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--border-card",
      "--border-hairline",
      "--border-icon",
      "--color-bg",
      "--color-border",
      "--color-fg",
      "--color-fg-muted",
      "--color-fg-on-primary",
      "--color-link",
      "--color-primary",
      "--color-primary-dark",
      "--color-primary-hover",
      "--color-surface",
      "--color-surface-alt",
      "--font-mono",
      "--font-sans",
      "--fs-body",
      "--fs-caption",
      "--fs-cell",
      "--fs-display",
      "--fs-h1",
      "--fs-h2",
      "--fs-nav",
      "--fw-black",
      "--fw-bold",
      "--fw-medium",
      "--fw-regular",
      "--fw-semibold",
      "--lh-body",
      "--lh-snug",
      "--lh-tight",
      "--r-0",
      "--r-lg",
      "--r-md",
      "--r-pill",
      "--r-sm",
      "--ring-focus",
      "--shadow-lg",
